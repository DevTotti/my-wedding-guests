{
  "name": "my-wedding-guest",
  "version": "1.0.0",
  "description": "Wedding access card system with QR code generation, guest attendance tracking, and admin management",
  "scripts": {
    "pretty": "prettier --write \"src/**/*.ts\"",
    "prisma:studio": "prisma studio",
    "prisma:format": "prisma format",
    "push:db": "prisma db push",
    "generate:prisma": "prisma generate",
    "build-ts": "tsc",
    "build": "npm run pretty && npm -s run generate:prisma && npm run build-ts",
    "debug": "npm run build && npm run watch-debug",
    "lint": "tsc --noEmit && eslint '**/*.{js,ts}' --quiet --fix",
    "serve-debug": "nodemon --inspect dist/server.js",
    "serve": "node dist/server.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "npm run watch",
    "start": "prisma migrate deploy && npm run pretty && npm run serve",
    "watch-debug": "concurrently -k -p \"[{name}]\" -n \"Sass,TypeScript,Node\" -c \"yellow.bold,cyan.bold,green.bold\" \"npm run watch-sass\" \"npm run watch-ts\" \"npm run serve-debug\"",
    "watch-node": "nodemon dist/server.js",
    "watch-test": "npm run test -- --watchAll",
    "watch-ts": "tsc -w"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "compression": "1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "errorhandler": "1.5.1",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "express-session": "^1.18.1",
    "http-status-codes": "^2.2.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.15",
    "qrcode": "^1.5.4",
    "sharp": "^0.33.5",
    "pdfkit": "^0.15.0",
    "uuid": "^10.0.0",
    "winston": "^3.19.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "1.7.0",
    "@types/cors": "^2.8.17",
    "@types/errorhandler": "1.5.0",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/hapi__joi": "^17.1.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/nodemailer": "^6.4.16",
    "@types/node": "^22.0.0",
    "@types/pdfkit": "^0.13.4",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^10.0.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.1",
    "prettier": "^3.3.2",
    "typescript": "^5.5.4",
    "@types/winston": "2.4.4"
  }
}